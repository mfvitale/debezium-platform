{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "conductor": {
            "properties": {
                "image": {
                    "type": "string"
                },
                "imagePullPolicy": {
                    "type": "string",
                    "enum": ["IfNotPresent", "Always", "Never"]
                },
                "offset": {
                    "properties": {
                        "existingConfigMap": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "descriptors": {
                    "type": "object",
                    "properties": {
                        "official": {
                            "type": "object",
                            "properties": {
                                "enabled": {
                                    "type": "boolean",
                                    "default": true,
                                    "description": "Enable official Debezium descriptors (downloaded via ORAS at startup)"
                                },
                                "registry": {
                                    "type": "string",
                                    "default": "quay.io",
                                    "description": "Registry hosting the descriptor OCI artifact"
                                },
                                "image": {
                                    "type": "string",
                                    "default": "debezium/debezium-descriptors",
                                    "description": "Image name for the descriptor OCI artifact"
                                },
                                "tag": {
                                    "type": "string",
                                    "default": "nightly",
                                    "description": "Image tag for the descriptor OCI artifact"
                                },
                                "mountPath": {
                                    "type": "string",
                                    "default": "/opt/descriptors",
                                    "description": "Path where descriptors will be downloaded inside the container"
                                }
                            },
                            "required": ["enabled", "registry", "image", "tag", "mountPath"]
                        }
                    }
                }
            },
            "type": "object"
        },
        "database": {
            "properties": {
                "auth": {
                    "properties": {
                        "existingSecret": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "enabled": {
                    "type": "boolean"
                },
                "host": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "domain": {
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "deprecated": true
                }
            },
            "type": "object"
        },
        "env": {
            "type": "array"
        },
        "offset": {
            "properties": {
                "database": {
                    "properties": {
                        "auth": {
                            "properties": {
                                "existingSecret": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        },
                        "host": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "password": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer"
                        },
                        "username": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "reusePlatformDatabase": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "schemaHistory": {
            "properties": {
                "database": {
                    "properties": {
                        "auth": {
                            "properties": {
                                "existingSecret": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        },
                        "host": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "password": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer"
                        },
                        "username": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "reusePlatformDatabase": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "stage": {
            "properties": {
                "image": {
                    "type": "string"
                },
                "imagePullPolicy": {
                    "type": "string",
                    "enum": ["IfNotPresent", "Always", "Never"]
                }
            },
            "type": "object"
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "className": {
              "type": "string",
              "default": ""
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "secretName": {
                  "type": "string",
                  "default": ""
                }
              },
              "required": ["enabled"]
            }
          },
          "required": ["enabled", "tls"]
        }
    },
    "type": "object"
}

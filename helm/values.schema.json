{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "conductor": {
            "properties": {
                "image": {
                    "type": "string"
                },
                "imagePullPolicy": {
                    "type": "string",
                    "enum": ["IfNotPresent", "Always", "Never"]
                },
                "offset": {
                    "properties": {
                        "existingConfigMap": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "descriptors": {
                    "type": "object",
                    "properties": {
                        "official": {
                            "type": "object",
                            "properties": {
                                "enabled": {
                                    "type": "boolean",
                                    "default": true,
                                    "description": "Enable official Debezium descriptors (downloaded via ORAS at startup)"
                                },
                                "registry": {
                                    "type": "string",
                                    "default": "quay.io",
                                    "description": "Registry hosting the descriptor OCI artifact"
                                },
                                "image": {
                                    "type": "string",
                                    "default": "debezium/debezium-descriptors",
                                    "description": "Image name for the descriptor OCI artifact"
                                },
                                "tag": {
                                    "type": "string",
                                    "default": "nightly",
                                    "description": "Image tag for the descriptor OCI artifact"
                                },
                                "mountPath": {
                                    "type": "string",
                                    "default": "/opt/descriptors",
                                    "description": "Path where descriptors will be downloaded inside the container"
                                }
                            },
                            "required": ["enabled", "registry", "image", "tag", "mountPath"]
                        }
                    }
                },
                "extraVolumes": {
                    "type": "array",
                    "default": []
                },
                "extraVolumeMounts": {
                    "type": "array",
                    "default": []
                }
            },
            "type": "object"
        },
        "database": {
            "properties": {
                "auth": {
                    "properties": {
                        "existingSecret": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "enabled": {
                    "type": "boolean"
                },
                "host": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            },
            "type": "object"
        },
        "debezium-operator": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "domain": {
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "deprecated": true
                }
            },
            "type": "object"
        },
        "env": {
            "type": "array"
        },
        "offset": {
            "properties": {
                "database": {
                    "properties": {
                        "auth": {
                            "properties": {
                                "existingSecret": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        },
                        "host": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "password": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer"
                        },
                        "username": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "reusePlatformDatabase": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "schemaHistory": {
            "properties": {
                "database": {
                    "properties": {
                        "auth": {
                            "properties": {
                                "existingSecret": {
                                    "type": "string"
                                }
                            },
                            "type": "object"
                        },
                        "host": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        },
                        "password": {
                            "type": "string"
                        },
                        "port": {
                            "type": "integer"
                        },
                        "username": {
                            "type": "string"
                        }
                    },
                    "type": "object"
                },
                "reusePlatformDatabase": {
                    "type": "boolean"
                }
            },
            "type": "object"
        },
        "stage": {
            "properties": {
                "image": {
                    "type": "string"
                },
                "imagePullPolicy": {
                    "type": "string",
                    "enum": ["IfNotPresent", "Always", "Never"]
                }
            },
            "type": "object"
        },
        "server": {
            "properties": {
                "image": {
                    "type": "string",
                    "default": "",
                    "description": "Image for Debezium Server instances created by pipelines. If empty, the operator's ServerImageProvider determines the image"
                }
            },
            "type": "object"
        },
        "pipeline": {
            "type": "object",
            "properties": {
                "labels": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    },
                    "default": {},
                    "description": "Map of labels to apply to DebeziumServer custom resources created by pipelines"
                }
            }
        },
        "monitoring": {
            "type": "object",
            "description": "Monitoring configuration for OpenTelemetry and Prometheus",
            "properties": {
                "otel": {
                    "type": "object",
                    "properties": {
                        "enabled": {
                            "type": "boolean",
                            "default": false,
                            "description": "Enable OpenTelemetry monitoring infrastructure"
                        },
                        "collector": {
                            "type": "object",
                            "properties": {
                                "image": {
                                    "type": "string",
                                    "default": "",
                                    "description": "Override OTel Collector image. If empty, the operator's default is used. Must include the Prometheus exporter (available in the base otelcol and contrib distributions, but not in otelcol-k8s)"
                                },
                                "replicas": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "default": 1,
                                    "description": "Number of OTel Collector replicas"
                                },
                                "receivers": {
                                    "type": "object",
                                    "properties": {
                                        "grpc": {
                                            "type": "object",
                                            "properties": {
                                                "port": {
                                                    "type": "integer",
                                                    "default": 4317
                                                }
                                            }
                                        },
                                        "http": {
                                            "type": "object",
                                            "properties": {
                                                "port": {
                                                    "type": "integer",
                                                    "default": 4318
                                                }
                                            }
                                        }
                                    }
                                },
                                "processors": {
                                    "type": "object",
                                    "properties": {
                                        "batch": {
                                            "type": "object",
                                            "properties": {
                                                "timeout": {
                                                    "type": "string",
                                                    "default": "5s"
                                                },
                                                "sendBatchSize": {
                                                    "type": "integer",
                                                    "default": 512
                                                }
                                            }
                                        }
                                    }
                                },
                                "exporters": {
                                    "type": "object",
                                    "properties": {
                                        "prometheus": {
                                            "type": "object",
                                            "properties": {
                                                "port": {
                                                    "type": "integer",
                                                    "default": 8889
                                                },
                                                "resourceToTelemetryConversion": {
                                                    "type": "boolean",
                                                    "default": true
                                                },
                                                "constLabels": {
                                                    "type": "object",
                                                    "additionalProperties": {
                                                        "type": "string"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "prometheus": {
                    "type": "object",
                    "properties": {
                        "external": {
                            "type": "object",
                            "properties": {
                                "url": {
                                    "type": "string",
                                    "default": "",
                                    "description": "URL of an external Prometheus instance (for users not using Prometheus Operator)"
                                }
                            }
                        },
                        "serviceMonitor": {
                            "type": "object",
                            "properties": {
                                "enabled": {
                                    "type": "boolean",
                                    "default": true,
                                    "description": "Create a ServiceMonitor for the OTel Collector"
                                },
                                "scrapeInterval": {
                                    "type": "string",
                                    "default": "15s"
                                },
                                "labels": {
                                    "type": "object",
                                    "additionalProperties": {
                                        "type": "string"
                                    },
                                    "description": "Labels for Prometheus Operator discovery"
                                }
                            }
                        }
                    }
                }
            }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "className": {
              "type": "string",
              "default": ""
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "tls": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "secretName": {
                  "type": "string",
                  "default": ""
                }
              },
              "required": ["enabled"]
            }
          },
          "required": ["enabled", "tls"]
        }
    },
    "type": "object"
}
